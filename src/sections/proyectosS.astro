---
import Cardporta from '../components/cardPorta.astro';
import { misProyectos } from '../utils/datosporta.js';
---
<section id="two">
    <h2>Proyectos Destacados</h2>
    <div class="row">
        {misProyectos.map((proyecto: any) => (
            <Cardporta 
                linkGithub={proyecto.linkGithub} 
                imagenM={proyecto.imagenM} 
                titulo={proyecto.titulo} 
                descripcion={proyecto.descripcion} 
            />
        ))}
    </div>
</section>