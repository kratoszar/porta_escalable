---
import Botoncv from '../components/botoncv.astro';
import { getSection } from 'emdash';
const seccionPresentacion = await getSection('presentacion');
const bloquesDeContenido = seccionPresentacion?.content || [];
---

<section id="one">
  {bloquesDeContenido.map((bloque: any) => {
    const Etiqueta = bloque.style === 'normal' || !bloque.style ? 'p' : bloque.style;
    const textoDelBloque = bloque.children?.map((hijo: any) => {
      return hijo.marks?.includes('strong') ? <strong>{hijo.text}</strong> : hijo.text;
    });
    if (Etiqueta === 'h2') {
      return (
        <header class="major">
          <Etiqueta>{textoDelBloque}</Etiqueta>
        </header>
      );
    }
    return <Etiqueta>{textoDelBloque}</Etiqueta>;
  })}
  <ul class="actions">
    <li><Botoncv /></li>
  </ul>
</section>